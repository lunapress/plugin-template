{
    "name": "lunapress/plugin-template",
    "autoload": {
        "psr-4": {
            "LunaPress\\PluginTemplate\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Onepix",
            "homepage": "https://onepix.net",
            "role": "Company"
        },
        {
            "name": "0zd0",
            "role": "Lead Developer",
            "homepage": "https://github.com/0zd0"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": false,
    "require": {
        "php": "^8.3",
        "lunapress/core": "dev-main",
        "lunapress/frontend-kit": "dev-main",
        "lunapress/php-di-adapter": "dev-main",
        "lunapress/wp-i18n": "dev-main"
    },
    "require-dev": {
        "lunapress/static-analysis": "dev-main",
        "lunapress/cli": "dev-nightly"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3"
        }
    },
    "scripts": {
        "i18n:make-pot": "lunapress i18n:make-pot",
        "vendor:prefix": "lunapress vendor:prefix",
        "build:archive": "lunapress build:archive",

        "fix:phpcs": "lunapress-static-analysis phpcbf",
        "check:phpcs": "lunapress-static-analysis phpcs",
        "check:psalm": "lunapress-static-analysis psalm -- --no-cache",
        "check": [
            "@check:phpcs",
            "@check:psalm"
        ]
    }
}
