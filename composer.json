{
    "name": "lunapress/plugin-template",
    "autoload": {
        "psr-4": {
            "LunaPress\\PluginTemplate\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Onepix",
            "homepage": "https://onepix.net",
            "role": "Company"
        },
        {
            "name": "0zd0",
            "role": "Lead Developer",
            "homepage": "https://github.com/0zd0"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "brianhenryie/strauss-phar",
                "version": "0.27.0",
                "dist": {
                    "url": "https://github.com/BrianHenryIE/strauss/releases/download/0.27.0/strauss.phar",
                    "type": "file",
                    "shasum": "437c9a43cafbd60eeb22d09f83d1fcd939140c00"
                },
                "bin": [
                    "strauss.phar"
                ]
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "lunapress/core": "@dev",
        "lunapress/frontend-kit": "@dev",
        "lunapress/php-di-adapter": "@dev",
        "lunapress/wp-i18n": "@dev"
    },
    "require-dev": {
        "lunapress/static-analysis": "@dev",
        "lunapress/cli": "dev-nightly"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3"
        }
    },
    "scripts": {
        "i18n:make-pot": "lunapress i18n:make-pot",
        "vendor:prefix": "lunapress vendor:prefix",
        "build:archive": "lunapress build:archive",

        "fix:phpcs": "lunapress-static-analysis phpcbf",
        "check:phpcs": "lunapress-static-analysis phpcs",
        "check:psalm": "lunapress-static-analysis psalm -- --no-cache",
        "check": [
            "@check:phpcs",
            "@check:psalm"
        ]
    }
}
